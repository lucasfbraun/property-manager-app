{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "property-manager-app",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "property-manager-db",
      "database_id": "eae4e82d-e0e0-483e-8247-e5c471c8d0aa"
    }
  ],
  "observability": {
    "enabled": true
  }
}
